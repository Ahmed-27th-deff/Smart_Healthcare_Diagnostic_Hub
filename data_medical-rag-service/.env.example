# Copy this file to .env and fill in your real values.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash-lite

# =============================
# ML model config - based on the notebook
# =============================
# Notebook target: Diabetes_binary
# Save your trained sklearn model + StandardScaler in models/ml_model.pkl as:
# {
#   "model": best_ml_model,
#   "preprocessor": scaler_p,
#   "feature_names": [...same feature list below...],
#   "threshold": 0.5,
#   "labels": ["No Diabetes Risk", "Diabetes Risk"]
# }
ML_MODEL_PATH=models/ml_model.pkl
ML_PREPROCESSOR_PATH=
ML_FEATURE_NAMES=HighBP,HighChol,BMI,Smoker,Stroke,HeartDiseaseorAttack,PhysActivity,HvyAlcoholConsump,NoDocbcCost,GenHlth,MentHlth,PhysHlth,DiffWalk,Age,Education,Income,GenHlth_BMI,Age_HighBP,PhysHlth_NoActivity
ML_POSITIVE_CLASS_INDEX=1
ML_THRESHOLD=0.5
ML_LABEL_NEGATIVE=No Diabetes Risk
ML_LABEL_POSITIVE=Diabetes Risk

# =============================
# DL model config - based on the notebook
# =============================
# Notebook model: DenseNet121 binary X-ray classifier.
# Trained with ImageDataGenerator(rescale=1./255), target_size=(224,224).
# Copy checkpoints/best_model_recall.keras to models/dl_model.keras, or change this path.
DL_MODEL_PATH=models/dl_model.keras
DL_FRAMEWORK=keras
DL_IMAGE_SIZE=224,224
DL_THRESHOLD=0.3
DL_LABEL_NEGATIVE=Normal X-ray
DL_LABEL_POSITIVE=Pneumonia

# PyTorch normalization only. Keras path uses image / 255.0 by default.
DL_MEAN=0.485,0.456,0.406
DL_STD=0.229,0.224,0.225

# Number of retrieved evidence chunks passed to Gemini.
RAG_TOP_K=4
